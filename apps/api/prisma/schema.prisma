generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id              String       @id @default(uuid())
  name            String
  subdomain       String       @unique
  address         String       @default("")
  brand_color     String?      @default("#2563eb")
  logo_url        String?
  welcome_text    String?   @default("Welcome. How can we help your stay?")
  commission_rate Float        @default(15.0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  bookings        Booking[]
  staff           HotelStaff[]
}

model HotelStaff {
  id        String   @id @default(uuid())
  hotelId   String
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  hotel     Hotel    @relation(fields: [hotelId], references: [id])
}

model Driver {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String
  phone             String    @unique
  status            String    @default("OFFLINE")
  lat               Float?
  lng               Float?
  isApproved        Boolean   @default(false)
  isOnline          Boolean   @default(false)
  lastSeenAt        DateTime?
  isRejected        Boolean   @default(false)
  vehicleMake       String?
  vehicleModel      String?
  vehicleReg        String?
  vehicleColour     String?
  licenceDoc        String?
  phLicenceDoc      String?
  insuranceDoc      String?
  motDoc            String?
  profilePhoto      String?
  licenceExpiry     DateTime?
  phLicenceExpiry   DateTime?
  insuranceExpiry   DateTime?
  motExpiry         DateTime?
  adminNotes        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  bookings          Booking[]
}

model Booking {
  id              String    @id @default(uuid())
  hotelId         String
  driverId        String?
  guestName       String    @default("")
  guestPhone      String    @default("")
  notes           String    @default("")
  pickupAddress   String
  dropoffAddress  String
  scheduledFor    DateTime?
  status          String    @default("PENDING")
  fare            Float
  hotelCommission Float
  driverPayout    Float     @default(0)
  passengerCount  Int       @default(1)
  distanceMiles   Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  driver          Driver?   @relation(fields: [driverId], references: [id])
  hotel           Hotel     @relation(fields: [hotelId], references: [id])
}
